# Token akses Facebook Graph API
ACCESS_TOKEN=#

# ID Instagram Business Account (angka)
IG_USER_ID=#

# Periode filter (YYYY-MM-DD), kosongkan untuk ambil semua
DATE_FROM=
DATE_TO=

# Direktori output (default: data/)
OUTPUT_DIR=data

# WordPress Auto-Post
WP_ENABLED=false
WP_URL=https://yoursite.com
WP_USER=admin
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx
WP_POST_STATUS=draft
WP_TEMPLATE_POST_ID=2542
